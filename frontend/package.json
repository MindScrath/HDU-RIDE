{
  "name": "hdu-ride-frontend",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "bun ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && bun ./node_modules/vite/bin/vite.js build",
    "preview": "bun ./node_modules/vite/bin/vite.js preview --host 0.0.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.7",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.8"
  }
}
